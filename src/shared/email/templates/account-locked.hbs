<html lang='{{lang}}'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{{t 'email.accountLocked.subtitle'}}</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        background-color: #f0f0f0;
        color: #333333;
        line-height: 1.6;
      }
      .email-wrapper {
        width: 100%;
        padding: 40px 20px;
        background-color: #f0f0f0;
      }
      .email-container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }
      .email-header {
        background: linear-gradient(135deg, #ff0000 0%, #8b0707 100%);
        padding: 40px 30px;
        text-align: center;
        color: #ffffff;
      }
      .email-header h1 {
        font-size: 28px;
        font-weight: 600;
        margin-bottom: 8px;
      }
      .email-header p {
        font-size: 16px;
        opacity: 0.9;
      }
      .icon-warning {
        font-size: 60px;
        margin-bottom: 15px;
      }
      .email-body {
        padding: 40px 30px;
      }
      .greeting {
        font-size: 18px;
        color: #333333;
        margin-bottom: 20px;
      }
      .content-text {
        font-size: 15px;
        color: #666666;
        margin-bottom: 20px;
        line-height: 1.7;
      }
      .alert-box {
        background-color: #fff5f5;
        border: 2px solid #ff0000;
        border-radius: 8px;
        padding: 20px;
        margin: 25px 0;
      }
      .alert-box-title {
        font-size: 16px;
        font-weight: 600;
        color: #ff0000;
        margin-bottom: 10px;
      }
      .alert-box-text {
        font-size: 14px;
        color: #666666;
        margin: 0;
      }
      .button-container {
        text-align: center;
        margin: 30px 0;
      }
      .button {
        display: inline-block;
        background-color: #000000;
        color: #ffffff;
        padding: 14px 32px;
        text-decoration: none;
        border-radius: 6px;
        font-weight: 600;
        font-size: 15px;
        transition: background-color 0.3s;
      }
      .steps-container {
        background-color: #f0f0f0;
        border-radius: 8px;
        padding: 25px;
        margin: 25px 0;
      }
      .steps-title {
        font-size: 16px;
        font-weight: 600;
        color: #333333;
        margin-bottom: 15px;
      }
      .step {
        display: flex;
        margin-bottom: 12px;
        font-size: 14px;
        color: #666666;
      }
      .step-number {
        background-color: #c4ae72;
        color: #ffffff;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 12px;
        margin-right: 12px;
        flex-shrink: 0;
      }
      .info-box {
        background-color: #f0f0f0;
        border-left: 4px solid #007bff;
        padding: 16px 20px;
        margin: 20px 0;
        border-radius: 4px;
      }
      .info-box p {
        font-size: 14px;
        color: #666666;
        margin: 0;
      }
      .email-footer {
        background-color: #f0f0f0;
        padding: 30px;
        text-align: center;
        border-top: 1px solid #ededed;
      }
      .footer-text {
        font-size: 13px;
        color: #666666;
        margin-bottom: 8px;
      }
      .footer-links {
        margin-top: 15px;
      }
      .footer-links a {
        color: #c4ae72;
        text-decoration: none;
        margin: 0 10px;
        font-size: 13px;
      }
    </style>
  </head>
  <body>
    <div class='email-wrapper'>
      <div class='email-container'>
        <div class='email-header'>
          <h1>{{t 'email.title'}}</h1>
          <p>{{t 'email.accountLocked.subtitle'}}</p>
        </div>

        <div class='email-body'>

          <p class='content-text'>
            {{t 'email.accountLocked.body'}}
          </p>

          <div class='alert-box'>
            <p class='alert-box-text'>
              {{t 'email.accountLocked.alertText'}}
            </p>
          </div>

          <div class='steps-container'>
            <div class='steps-title'>{{t
                'email.accountLocked.stepsTitle'
              }}</div>
            <div class='step'>
              <div class='step-number'>1</div>
              <div>{{t 'email.accountLocked.step1'}}</div>
            </div>
            <div class='step'>
              <div class='step-number'>2</div>
              <div>{{t 'email.accountLocked.step2'}}</div>
            </div>
            <div class='step'>
              <div class='step-number'>3</div>
              <div>{{t 'email.accountLocked.step3'}}</div>
            </div>
            <div class='step'>
              <div class='step-number'>4</div>
              <div>{{t 'email.accountLocked.step4'}}</div>
            </div>
          </div>

          <div class='button-container'>
            <a
              href='{{clientUrl}}/forgot-password'
              class='button'
              style='background-color: #000000; color: #ffffff; padding: 14px 40px; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 15px;'
            >
              {{t 'email.accountLocked.buttonText'}}
            </a>
          </div>

          <div class='info-box'>
            <p><strong>💡 {{t 'email.accountLocked.wasntYou'}}</strong>
              {{t 'email.accountLocked.wasntYouText'}}</p>
          </div>

          <p class='content-text' style='margin-top: 30px;'>
            <strong>{{t 'email.accountLocked.lockedOn'}}: </strong>
            {{currentDate}}
          </p>
        </div>

        <div class='email-footer'>
          <p class='footer-text'>&copy;
            {{currentYear}}
            {{t 'email.footer'}}</p>
          <div class='footer-links'>
            <a href='#'>{{t 'email.privacyPolicy'}}</a>
            <a href='#'>{{t 'email.contactSupport'}}</a>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>