<html lang='{{lang}}'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{{t 'email.passwordReset.subtitle'}}</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        background-color: #f0f0f0;
        color: #333333;
        line-height: 1.6;
      }
      .email-wrapper {
        width: 100%;
        padding: 40px 20px;
        background-color: #f0f0f0;
      }
      .email-container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }
      .email-header {
        background: linear-gradient(135deg, #000000 0%, #333333 100%);
        padding: 40px 30px;
        text-align: center;
        color: #ffffff;
      }
      .email-header h1 {
        font-size: 28px;
        font-weight: 600;
        margin-bottom: 8px;
      }
      .email-header p {
        font-size: 16px;
        opacity: 0.85;
      }
      .email-body {
        padding: 40px 30px;
      }
      .greeting {
        font-size: 18px;
        color: #000000;
        margin-bottom: 20px;
      }
      .content-text {
        font-size: 15px;
        color: #333333;
        margin-bottom: 30px;
        line-height: 1.7;
      }
      .code-container {
        background: linear-gradient(135deg, #f9f9f9 0%, #efefef 100%);
        border: 2px dashed #c4ae72;
        border-radius: 12px;
        padding: 30px;
        text-align: center;
        margin: 30px 0;
      }
      .code-label {
        font-size: 13px;
        color: #666666;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
      }
      .code {
        font-size: 42px;
        font-weight: 700;
        color: #000000;
        letter-spacing: 8px;
        font-family: 'Courier New', monospace;
        margin: 10px 0;
      }
      .code-expiry {
        font-size: 13px;
        color: #999999;
        margin-top: 12px;
      }
      .warning-box {
        background-color: #fff5f5;
        border-left: 4px solid #ff0000;
        padding: 16px 20px;
        margin: 20px 0;
        border-radius: 4px;
      }
      .warning-box p {
        font-size: 14px;
        color: #333333;
        margin: 0;
      }
      .info-box {
        background-color: #f0f8ff;
        border-left: 4px solid #007bff;
        padding: 16px 20px;
        margin: 20px 0;
        border-radius: 4px;
      }
      .info-box p {
        font-size: 14px;
        color: #333333;
        margin: 0;
      }
      .email-footer {
        background-color: #f0f0f0;
        padding: 30px;
        text-align: center;
        border-top: 1px solid #ededed;
      }
      .footer-text {
        font-size: 13px;
        color: #666666;
        margin-bottom: 8px;
      }
      .footer-links {
        margin-top: 15px;
      }
      .footer-links a {
        color: #c4ae72;
        text-decoration: none;
        margin: 0 10px;
        font-size: 13px;
      }
    </style>
  </head>
  <body>
    <div class='email-wrapper'>
      <div class='email-container'>
        <div class='email-header'>
          <h1>{{t 'email.title'}}</h1>
          <p>{{t 'email.passwordReset.subtitle'}}</p>
        </div>

        <div class='email-body'>
          <p class='greeting'>{{t 'email.passwordReset.greeting'}},</p>

          <p class='content-text'>{{t 'email.passwordReset.body'}}</p>

          <div class='code-container'>
            <div class='code-label'>{{t 'email.passwordReset.codeLabel'}}</div>
            <div class='code'>{{code}}</div>
            <div class='code-expiry'>
              ⏱
              {{t 'email.passwordReset.expiresIn'}}</div>
          </div>

          <div class='warning-box'>
            <p><strong>⚠️ {{t 'email.passwordReset.securityNotice'}}:</strong>
              {{t 'email.passwordReset.securityText'}}</p>
          </div>

          <div class='info-box'>
            <p><strong>💡 {{t 'email.passwordReset.didntRequest'}}</strong>
              {{t 'email.passwordReset.didntRequestText'}}</p>
          </div>
        </div>

        <div class='email-footer'>
          <p class='footer-text'>&copy;
            {{currentYear}}
            {{t 'email.footer'}}</p>
          <div class='footer-links'>
            <a href='#'>{{t 'email.privacyPolicy'}}</a>
            <a href='#'>{{t 'email.contactSupport'}}</a>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>