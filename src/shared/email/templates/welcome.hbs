<html lang='{{lang}}'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{{t 'email.welcome.subtitle'}}</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        background-color: #f0f0f0;
        color: #333333;
        line-height: 1.6;
      }
      .email-wrapper {
        width: 100%;
        padding: 40px 20px;
        background-color: #f0f0f0;
      }
      .email-container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }
      .email-header {
        background: linear-gradient(135deg, #000000 0%, #333333 100%);
        padding: 50px 30px;
        text-align: center;
        color: #ffffff;
      }
      .icon-welcome {
        font-size: 70px;
        margin-bottom: 20px;
      }
      .email-header h1 {
        font-size: 32px;
        font-weight: 600;
        margin-bottom: 10px;
      }
      .email-header p {
        font-size: 18px;
        opacity: 0.85;
      }
      .email-body {
        padding: 40px 30px;
      }
      .greeting {
        font-size: 22px;
        color: #000000;
        margin-bottom: 20px;
        font-weight: 600;
      }
      .content-text {
        font-size: 15px;
        color: #333333;
        margin-bottom: 20px;
        line-height: 1.7;
      }
      .success-box {
        background: linear-gradient(135deg, #4fae6615 0%, #4fae6625 100%);
        border: 2px solid #4fae66;
        border-radius: 8px;
        padding: 20px;
        margin: 25px 0;
        text-align: center;
      }
      .success-box-icon {
        font-size: 40px;
        margin-bottom: 10px;
      }
      .success-box-title {
        font-size: 18px;
        font-weight: 600;
        color: #4fae66;
        margin-bottom: 8px;
      }
      .success-box-text {
        font-size: 14px;
        color: #333333;
      }
      .features-container {
        background-color: #f0f0f0;
        border-radius: 8px;
        padding: 25px;
        margin: 25px 0;
      }
      .features-title {
        font-size: 18px;
        font-weight: 600;
        color: #000000;
        margin-bottom: 20px;
        text-align: center;
      }
      .feature {
        display: flex;
        align-items: start;
        margin-bottom: 16px;
        padding: 12px;
        background-color: #ffffff;
        border-radius: 6px;
      }
      .feature-icon {
        font-size: 24px;
        margin-right: 15px;
        flex-shrink: 0;
      }
      .feature-content {
        flex: 1;
      }
      .feature-title {
        font-size: 15px;
        font-weight: 600;
        color: #000000;
        margin-bottom: 4px;
      }
      .feature-text {
        font-size: 13px;
        color: #666666;
      }
      .button-container {
        text-align: center;
        margin: 35px 0;
      }
      .email-footer {
        background-color: #f0f0f0;
        padding: 30px;
        text-align: center;
        border-top: 1px solid #ededed;
      }
      .footer-text {
        font-size: 13px;
        color: #666666;
        margin-bottom: 8px;
      }
      .footer-links {
        margin-top: 15px;
      }
      .footer-links a {
        color: #c4ae72;
        text-decoration: none;
        margin: 0 10px;
        font-size: 13px;
      }
    </style>
  </head>
  <body>
    <div class='email-wrapper'>
      <div class='email-container'>
        <div class='email-header'>
          <h1>{{t 'email.title'}}</h1>
          <p>{{t 'email.welcome.subtitle'}}</p>
        </div>

        <div class='email-body'>
          <p class='greeting'>{{t
              'email.welcome.greeting'
              name=name
              surname=surname
            }}</p>

          <p class='content-text'>
            {{{t 'email.welcome.body'}}}
          </p>

          <div class='features-container'>
            <div class='features-title'>{{t 'email.welcome.whatYouCanDo'}}</div>

            <div class='feature'>
              <div class='feature-icon'>🛍️</div>
              <div class='feature-content'>
                <div class='feature-title'>{{t
                    'email.welcome.feature1Title'
                  }}</div>
                <div class='feature-text'>
                  {{t 'email.welcome.feature1Text'}}
                </div>
              </div>
            </div>

            <div class='feature'>
              <div class='feature-icon'>👤</div>
              <div class='feature-content'>
                <div class='feature-title'>{{t
                    'email.welcome.feature2Title'
                  }}</div>
                <div class='feature-text'>
                  {{t 'email.welcome.feature2Text'}}
                </div>
              </div>
            </div>

            <div class='feature'>
              <div class='feature-icon'>🎁</div>
              <div class='feature-content'>
                <div class='feature-title'>{{t
                    'email.welcome.feature3Title'
                  }}</div>
                <div class='feature-text'>
                  {{t 'email.welcome.feature3Text'}}
                </div>
              </div>
            </div>

            <div class='feature'>
              <div class='feature-icon'>📦</div>
              <div class='feature-content'>
                <div class='feature-title'>{{t
                    'email.welcome.feature4Title'
                  }}</div>
                <div class='feature-text'>
                  {{t 'email.welcome.feature4Text'}}
                </div>
              </div>
            </div>
          </div>

          <div class='button-container'>
            <a
              href='{{clientUrl}}'
              class='button'
              style='background-color: #000000; color: #ffffff; padding: 14px 40px; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 15px;'
            >
              {{t 'email.welcome.buttonText'}}
            </a>
          </div>

          <p class='content-text' style='margin-top: 30px'>
            {{t 'email.welcome.supportText'}}
          </p>
        </div>

        <div class='email-footer'>
          <p class='footer-text'>&copy;
            {{currentYear}}
            {{t 'email.footer'}}</p>
          <div class='footer-links'>
            <a href='#'>{{t 'email.privacyPolicy'}}</a>
            <a href='#'>{{t 'email.contactSupport'}}</a>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>